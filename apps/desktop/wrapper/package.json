{
  "name": "biomolexplorer",
  "version": "2.0.0",
  "description": "Interface Desktop para o BioMolExplorer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "sync-version": "node -e \"const fs=require('fs');const v=JSON.parse(fs.readFileSync('../../../package.json')).version;const p=JSON.parse(fs.readFileSync('package.json'));p.version=v;fs.writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n');console.log('[sync-version] version ->',v)\"",
    "build:linux-native": "npm run sync-version && npm install --no-workspaces && node scripts/pack-source.js && electron-builder --linux deb",
    "build:mac-native": "npm install --no-workspaces && node scripts/pack-source.js && electron-builder --mac dmg && node scripts/pack-release.js mac-native"
  },
  "build": {
    "appId": "com.onrender.biomolexplorer",
    "productName": "BioMolExplorer",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": "deb",
      "icon": "assets/icons",
      "category": "Science",
      "extraFiles": [
        {
          "from": "../BioMolExplorer-Launcher/init-native.sh",
          "to": "init-native.sh"
        },
        {
          "from": "../BioMolExplorer-Launcher/biomolexplorer-src.tar.gz",
          "to": "biomolexplorer-src.tar.gz"
        }
      ]
    },
    "deb": {
      "depends": [
        "curl",
        "psmisc"
      ],
      "maintainer": "Pedro Dias <pedro.dias@aluno.cefetmg.br>",
      "artifactName": "biomolexplorer_amd64.deb"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.education",
      "artifactName": "BioMolExplorer.dmg"
    }
  },
  "homepage": "https://biomolexplorer.onrender.com",
  "author": {
    "name": "Pedro Dias",
    "email": "pedro.dias@aluno.cefetmg.br"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "7zip-bin": "^5.2.0",
    "archiver": "^7.0.1",
    "electron": "^32.3.3",
    "electron-builder": "^24.13.3"
  }
}
