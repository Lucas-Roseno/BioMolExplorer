{
  "name": "biomolexplorer",
  "version": "2.0.0",
  "description": "Interface Desktop para o BioMolExplorer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:linux-native": "npm install --no-workspaces && node scripts/pack-source.js && electron-builder --linux AppImage && node scripts/pack-release.js linux-native",
    "build:mac-native": "npm install --no-workspaces && node scripts/pack-source.js && electron-builder --mac dmg && node scripts/pack-release.js mac-native"
  },
  "build": {
    "appId": "com.onrender.biomolexplorer",
    "productName": "BioMolExplorer",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icons",
      "category": "Science",
      "artifactName": "BioMolExplorer.AppImage"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.education",
      "artifactName": "BioMolExplorer.dmg"
    }
  },
  "author": "Pedro Dias",
  "license": "MIT",
  "devDependencies": {
    "7zip-bin": "^5.2.0",
    "archiver": "^7.0.1",
    "electron": "^32.3.3",
    "electron-builder": "^24.13.3"
  }
}
